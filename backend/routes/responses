const express = require('express');
const router = express.Router();
const responseController = require('../controllers/responseController');
const auth = require('../middleware/auth');
const roleCheck = require('../middleware/roleCheck');
const upload = require('../config/multer');

// Rutas para estudiantes
router.post('/submit', auth, roleCheck('estudiante'), upload.single('archivo'), responseController.submitResponse);
router.get('/assignment/:asignacionId', auth, roleCheck('estudiante'), responseController.getStudentResponse);

// Rutas para docentes
router.get('/case/:asignacionId/all', auth, roleCheck('docente'), responseController.getCaseResponses);
router.post('/grade', auth, roleCheck('docente'), responseController.gradeResponse);
router.get('/pending', auth, roleCheck('docente'), responseController.getPendingResponses);

module.exports = router;